//| mvnDeps: ["works.iterative::mill-iw-support::0.1.4-SNAPSHOT"]
// PURPOSE: Mill build definition for the claude-code-query Scala SDK.
// PURPOSE: Defines three modules: core (shared types/parsing), direct (Ox-based sync API), effectful (cats-effect/fs2 async API).
package build

import mill._, scalalib._, publish._
import works.iterative.mill._

trait SharedModule extends IWScalaModule with PublishModule {
  override def scalaVersion = IWScalaVersions.scala3LTSVersion
  def publishVersion = "0.1.0"
  override def artifactName = "claude-code-query-" + super.artifactName()
  def pomSettings = PomSettings(
    description = "Scala SDK for Claude Code CLI",
    organization = "works.iterative",
    url = "https://github.com/iterative-works/claude-code-query",
    licenses = Seq(License.`Apache-2.0`),
    versionControl = VersionControl.github("iterative-works", "claude-code-query"),
    developers = Seq(Developer("mph", "Michal Příhoda", "https://github.com/mprihoda"))
  )
}

object core extends SharedModule {
  def mvnDeps = Seq(
    mvn"io.circe::circe-core:0.14.15",
    mvn"io.circe::circe-parser:0.14.15",
    mvn"com.lihaoyi::os-lib:0.11.8"
  )

  object test extends ScalaTests with TestModule.Munit {
    def mvnDeps = Seq(
      mvn"org.scalameta::munit:1.1.1",
      mvn"org.typelevel::munit-cats-effect:2.1.0",
      mvn"org.scalacheck::scalacheck:1.18.1",
      mvn"org.scalameta::munit-scalacheck:1.1.0",
      mvn"co.fs2::fs2-core:3.13.0"
    )
  }
}

object direct extends SharedModule {
  def moduleDeps = Seq(core)
  def mvnDeps = Seq(
    mvn"com.lihaoyi::os-lib:0.11.8",
    mvn"com.softwaremill.ox::core:1.0.4",
    mvn"org.slf4j:slf4j-api:2.0.17"
  )

  object test extends ScalaTests with TestModule.Munit {
    def mvnDeps = Seq(
      mvn"org.scalameta::munit:1.1.1",
      mvn"org.scalacheck::scalacheck:1.18.1",
      mvn"org.scalameta::munit-scalacheck:1.1.0",
      mvn"ch.qos.logback:logback-classic:1.5.32"
    )
  }
}

object effectful extends SharedModule {
  def moduleDeps = Seq(core)
  def mvnDeps = Seq(
    mvn"com.lihaoyi::os-lib:0.11.8",
    mvn"org.typelevel::cats-effect:3.7.0",
    mvn"co.fs2::fs2-core:3.13.0",
    mvn"co.fs2::fs2-io:3.13.0",
    mvn"org.typelevel::log4cats-slf4j:2.8.0"
  )

  object test extends ScalaTests with TestModule.Munit {
    def moduleDeps = super.moduleDeps ++ Seq(direct.test)
    def mvnDeps = Seq(
      mvn"org.scalameta::munit:1.1.1",
      mvn"org.typelevel::munit-cats-effect:2.1.0",
      mvn"org.typelevel::log4cats-testing:2.7.1",
      mvn"ch.qos.logback:logback-classic:1.5.32"
    )
  }
}
